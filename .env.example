# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=scenemodels
DB_USER=postgres
DB_PASSWORD=postgres

# Server
PORT=3000
NODE_ENV=development
# Bind address (IPv6). Hosting may set IP; default when unset is :: (all IPv6 interfaces).
# IP=

# OAuth — GitHub / GitLab (see docs/auth.md)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
# GITLAB_BASE_URL=https://gitlab.example.com
# API_BASE_URL=http://localhost:3000
SESSION_SECRET=change-me-in-production
# SESSION_STORE=memory
# DATABASE_URL=postgres://user:pass@localhost:5432/scenemodels

# CORS + OAuth redirects (production = public site URL, e.g. https://example.com)
FRONTEND_URL=http://localhost:5173

# Dev only: API on another origin (Vite → API). Same-origin prod: omit.
# VITE_API_URL=http://localhost:3000

# Optional SPA static root (default: dist/public next to dist/server)
# CLIENT_DIST_PATH=/path/to/dist/public

# LOG_SQL=1
# LOG_LEVEL=debug
# CACHE_TTL_SECONDS=3600
# CACHE_TTL_MINUTES=60

UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

CAPTCHA_PUBLIC_KEY=your_public_key
CAPTCHA_PRIVATE_KEY=your_private_key

# EMAIL_QUEUE_BEARER_TOKEN=secret-for-email-queue-endpoints
