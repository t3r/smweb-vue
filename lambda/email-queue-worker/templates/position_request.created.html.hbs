<!DOCTYPE html>
<html>
<body style="font-family: system-ui, sans-serif; line-height: 1.5; color: #111;">
  <h2>New position request</h2>
  <p>A new item is waiting for review in the FlightGear scenemodels queue.</p>
  <table style="border-collapse: collapse;">
    <tr><td style="padding: 0.25rem 1rem 0.25rem 0;"><strong>Request ID</strong></td><td>{{requestId}}</td></tr>
    <tr><td style="padding: 0.25rem 1rem 0.25rem 0;"><strong>Type</strong></td><td>{{requestType}}</td></tr>
    <tr><td style="padding: 0.25rem 1rem 0.25rem 0;"><strong>Signature</strong></td><td><code>{{sig}}</code></td></tr>
  </table>
  {{#if positionRequestsUrl}}
  <p style="margin-top: 1.25rem; font-size: 0.9rem; color: #444;">
    <a href="{{positionRequestsUrl}}" style="color: #1d4ed8;">Open the position requests page</a> to review the queue.
  </p>
  {{/if}}
  <p style="margin-top: 1rem; font-size: 0.95rem; color: #374151;">Thank you for contributing to the FlightGear scenery community!</p>
</body>
</html>
