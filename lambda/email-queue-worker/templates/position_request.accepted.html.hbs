<!DOCTYPE html>
<html>
<body style="font-family: system-ui, sans-serif; line-height: 1.5; color: #111;">
  <h2>Request accepted</h2>
  <p>Your FlightGear scenemodels position request has been <strong>accepted</strong> and applied.</p>
  <table style="border-collapse: collapse;">
    <tr><td style="padding: 0.25rem 1rem 0.25rem 0;"><strong>Type</strong></td><td>{{requestType}}</td></tr>
  </table>
  {{#if summaryLines}}
  <div style="margin-top: 1rem;">
    <p style="margin: 0 0 0.35rem 0; font-weight: 600;">Request summary</p>
    <ul style="margin: 0; padding-left: 1.25rem;">
      {{#each summaryLines}}
      <li style="margin-bottom: 0.2rem;"><strong>{{label}}:</strong> {{value}}</li>
      {{/each}}
    </ul>
  </div>
  {{/if}}
  {{#if hasDetailLinks}}
  <p style="margin-top: 1rem;"><strong>View in the catalogue</strong></p>
  <ul style="margin: 0.25rem 0 0 1rem; padding: 0;">
    {{#each detailLinks}}
    <li style="margin: 0.35rem 0;"><a href="{{href}}" style="color: #1d4ed8;">{{label}}</a></li>
    {{/each}}
  </ul>
  {{/if}}
  <p style="margin-top: 1.5rem; font-size: 0.95rem; color: #374151;">Thank you for contributing to the FlightGear scenery community!</p>
</body>
</html>
